# ================================================================
# 旅途 AI 旅行规划助手 - 环境变量配置
# 使用：cp .env.example .env，然后编辑 .env 选择大模型方式
# ================================================================

# ── 大模型方式（二选一）──────────────────────────────────────────

# 方式一：本地 Ollama（默认，免费，数据不出境）
# 前提：安装 Ollama（https://ollama.com/download）后执行 ollama pull qwen3.5:0.8b
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen3.5:0.8b

# 方式二：DeepSeek API（效果更好，需要网络）
# 前提：注册 https://platform.deepseek.com 获取 API Key
# 切换方法：把上面三行注释掉，取消注释下面三行，填入 API Key
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-你的密钥
DEEPSEEK_MODEL=deepseek-chat

# ── 服务配置 ─────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173
CHAT_TEMPERATURE=0.7
MAX_ITERATIONS=6

# ── 天气 API（可选）──────────────────────────────────────────────
# 不填则使用内置模拟数据，不影响功能演示
# 注册：https://openweathermap.org/api
WEATHER_API_KEY=
